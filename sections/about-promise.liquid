{%- style -%}
  /* CSS Variables for About Promise Section */
  :root {
    --primary: #0d7ff2;
    --text-blue: #49739c;
    --gray-400: #9ca3af;
    --text-dark: #0d141c;
  }

  /* Dark Mode Variables */
  .dark {
    --gray-400: #9ca3af;
  }

  /* Promise Section */
  .about-promise-section-{{ section.id }} {
    width: 100%;
    border-radius: 0.75rem;
    padding: 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  {% if section.settings.background_color != blank %}
    .about-promise-section-{{ section.id }}::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: {{ section.settings.background_color }};
      opacity: {{ section.settings.background_opacity | default: 10 | divided_by: 100.0 }};
      border-radius: 0.75rem;
      z-index: 0;
    }
  {% else %}
    .about-promise-section-{{ section.id }}::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: #0d7ff2;
      opacity: 0.1;
      border-radius: 0.75rem;
      z-index: 0;
    }
  {% endif %}

  .dark .about-promise-section-{{ section.id }}::before {
    {% if section.settings.background_color != blank %}
      background-color: {{ section.settings.background_color }};
      opacity: {{ section.settings.background_opacity | default: 20 | divided_by: 100.0 }};
    {% else %}
      background-color: #0d7ff2;
      opacity: 0.2;
    {% endif %}
  }

  .about-promise-content-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    position: relative;
    z-index: 1;
  }

  .about-promise-icon-{{ section.id }} {
    {% if section.settings.icon_color != blank %}
      color: {{ section.settings.icon_color }};
    {% else %}
      color: var(--primary);
    {% endif %}
    font-size: {{ section.settings.icon_size | default: 48 }}px;
  }

  .about-promise-title-{{ section.id }} {
    {% if section.settings.title_color != blank %}
      color: {{ section.settings.title_color }};
    {% else %}
      color: rgb(var(--color-foreground));
    {% endif %}
    font-size: {{ section.settings.title_font_size_mobile | default: 24 }}px;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 0;
  }

  @media (min-width: 640px) {
    .about-promise-title-{{ section.id }} {
      font-size: {{ section.settings.title_font_size_desktop | default: 30 }}px;
    }
  }

  .about-promise-text-{{ section.id }} {
    font-size: {{ section.settings.text_font_size | default: 18 }}px;
    font-weight: 500;
    {% if section.settings.text_color != blank %}
      color: {{ section.settings.text_color }};
    {% else %}
      color: rgba(var(--color-foreground), 0.75);
    {% endif %}
    max-width: 80rem;
    margin: 0;
  }

  .about-promise-container-{{ section.id }} {
    margin: 0 auto;
    padding: {{ section.settings.padding_top | default: 40 }}px 1.5rem {{ section.settings.padding_bottom | default: 40 }}px;
  }

  {% if section.settings.width_type == 'custom' %}
    .about-promise-container-{{ section.id }} {
      max-width: {{ section.settings.custom_width | default: 1200 }}px;
    }
  {% elsif section.settings.width_type == 'full' %}
    .about-promise-container-{{ section.id }} {
      max-width: 100%;
      padding: {{ section.settings.padding_top | default: 40 }}px 0 {{ section.settings.padding_bottom | default: 40 }}px !important;
    }
  {% else %}
    .about-promise-container-{{ section.id }} {
      max-width: var(--page-width);
    }
  {% endif %}

  {% unless section.settings.width_type == 'full' %}
    @media screen and (min-width: 750px) {
      .about-promise-container-{{ section.id }} {
        padding-left: 5rem;
        padding-right: 5rem;
      }
    }
  {% endunless %}
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="about-promise-container-{{ section.id }}">
    <section class="about-promise-section-{{ section.id }}">
      <div class="about-promise-content-{{ section.id }}">
        <span class="material-symbols-outlined about-promise-icon-{{ section.id }}">
          {{ section.settings.icon | default: "workspace_premium" }}
        </span>
        <h2 class="about-promise-title-{{ section.id }}">{{ section.settings.title | default: "The Ink & Toner Store Promise" }}</h2>
        <p class="about-promise-text-{{ section.id }}">
          {{ section.settings.text | default: "Satisfaction Guaranteed on Every Single Order. If you're not 100% happy, we'll make it right." }}
        </p>
      </div>
    </section>
  </div>
</div>

{% schema %}
{
  "name": "About Promise",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "icon",
      "label": "Material Icon Name",
      "default": "workspace_premium",
      "info": "Enter Material Symbols icon name. Browse all icons at: https://fonts.google.com/icons"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "The Ink & Toner Store Promise"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Satisfaction Guaranteed on Every Single Order. If you're not 100% happy, we'll make it right."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#0d7ff2",
      "info": "Base color for the background"
    },
    {
      "type": "range",
      "id": "background_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Background Opacity",
      "default": 10,
      "info": "Opacity percentage for the background color"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#0d7ff2"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#0d7ff2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#0d141c"
    },
    {
      "type": "header",
      "content": "Font Sizes"
    },
    {
      "type": "range",
      "id": "title_font_size_mobile",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Title Font Size (Mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "title_font_size_desktop",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Title Font Size (Desktop)",
      "default": 30
    },
    {
      "type": "range",
      "id": "text_font_size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Text Font Size",
      "default": 18
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 32,
      "max": 96,
      "step": 4,
      "unit": "px",
      "label": "Icon Size",
      "default": 48
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "width_type",
      "label": "Section Width",
      "options": [
        {
          "value": "page",
          "label": "Page Width"
        },
        {
          "value": "full",
          "label": "Full Width"
        },
        {
          "value": "custom",
          "label": "Custom Width"
        }
      ],
      "default": "page"
    },
    {
      "type": "range",
      "id": "custom_width",
      "min": 400,
      "max": 2000,
      "step": 50,
      "unit": "px",
      "label": "Custom Max Width",
      "default": 1200,
      "info": "Only applies when Custom Width is selected"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "About Promise"
    }
  ]
}
{% endschema %}