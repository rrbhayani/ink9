  "presets": [
    {
      "name": "Shipping policy",
      "blocks": [
        { "type": "heading" },
        { "type": "intro" },
        { "type": "free_shipping" },
        { "type": "processing" },
        { "type": "shipping_options" },
        {
          "type": "shipping_option_row"
        },
        {
          "type": "shipping_option_row",
          "settings": {
            "name": "Expedited Shipping",
            "delivery_time": "1-3 Business Days",
            "price": "Calculated at Checkout"
          }
        },
        { "type": "carrier" },
        { "type": "returns_tracking" },
        { "type": "questions" }
      ]
    }
