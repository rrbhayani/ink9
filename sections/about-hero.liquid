{%- style -%}
  /* CSS Variables for About Hero Section */
  :root {
    --text-blue: #49739c;
    --gray-400: #9ca3af;
  }

  /* Dark Mode Variables */
  .dark {
    --gray-400: #9ca3af;
  }

  /* Page Heading Section */
  .about-hero-section-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
  }

  .about-hero-title-{{ section.id }} {
    color: rgb(var(--color-foreground));
    font-size: {{ section.settings.title_font_size_mobile | default: 36 }}px;
    line-height: 1.2;
    letter-spacing: -0.033em;
    font-weight: 900;
    margin: 0;
  }

  @media (min-width: 640px) {
    .about-hero-title-{{ section.id }} {
      font-size: {{ section.settings.title_font_size_desktop | default: 48 }}px;
    }
  }

  .about-hero-text-{{ section.id }} {
    color: rgba(var(--color-foreground), 0.75);
    font-size: {{ section.settings.text_font_size | default: 16 }}px;
    font-weight: 400;
    line-height: 1.75;
    max-width: 80rem;
    margin: 0;
  }

  .about-hero-container-{{ section.id }} {
    margin: 0 auto;
    padding: {{ section.settings.padding_top | default: 40 }}px 1.5rem {{ section.settings.padding_bottom | default: 40 }}px;
  }

  {% if section.settings.width_type == 'custom' %}
    .about-hero-container-{{ section.id }} {
      max-width: {{ section.settings.custom_width | default: 1200 }}px;
    }
  {% elsif section.settings.width_type == 'full' %}
    .about-hero-container-{{ section.id }} {
      max-width: 100%;
      padding: {{ section.settings.padding_top | default: 40 }}px 0 {{ section.settings.padding_bottom | default: 40 }}px !important;
    }
  {% else %}
    .about-hero-container-{{ section.id }} {
      max-width: var(--page-width);
    }
  {% endif %}

  {% unless section.settings.width_type == 'full' %}
    @media screen and (min-width: 750px) {
      .about-hero-container-{{ section.id }} {
        padding-left: 5rem;
        padding-right: 5rem;
      }
    }
  {% endunless %}
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="about-hero-container-{{ section.id }}">
    <section class="about-hero-section-{{ section.id }}">
      <h1 class="about-hero-title-{{ section.id }}">{{ section.settings.title | default: "Your Trusted Source for Ink & Toner" }}</h1>
      <p class="about-hero-text-{{ section.id }}">
        {{ section.settings.text | default: "Welcome to Ink & Toner Store, where we are dedicated to providing you with the highest quality printing supplies at the most competitive prices. Our journey began with a simple mission: to make printing easy, affordable, and reliable for everyone." }}
      </p>
    </section>
  </div>
</div>

{% schema %}
{
  "name": "About Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Your Trusted Source for Ink & Toner"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Welcome to Ink & Toner Store, where we are dedicated to providing you with the highest quality printing supplies at the most competitive prices. Our journey began with a simple mission: to make printing easy, affordable, and reliable for everyone."
    },
    {
      "type": "header",
      "content": "Font Sizes"
    },
    {
      "type": "range",
      "id": "title_font_size_mobile",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Title Font Size (Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "title_font_size_desktop",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Title Font Size (Desktop)",
      "default": 48
    },
    {
      "type": "range",
      "id": "text_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text Font Size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "width_type",
      "label": "Section Width",
      "options": [
        {
          "value": "page",
          "label": "Page Width"
        },
        {
          "value": "full",
          "label": "Full Width"
        },
        {
          "value": "custom",
          "label": "Custom Width"
        }
      ],
      "default": "page"
    },
    {
      "type": "range",
      "id": "custom_width",
      "min": 400,
      "max": 2000,
      "step": 50,
      "unit": "px",
      "label": "Custom Max Width",
      "default": 1200,
      "info": "Only applies when Custom Width is selected"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "About Hero"
    }
  ]
}
{% endschema %}

