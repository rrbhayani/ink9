<!-- Load Inter font -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&amp;display=swap" rel="stylesheet">
{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .contact-container-{{ section.id }} {
    max-width: 72rem;
    margin: 0 auto;
  }

  {% if section.settings.width_type == 'custom' %}
    .contact-container-{{ section.id }} {
      max-width: {{ section.settings.custom_width | default: 1200 }}px;
    }
  {% elsif section.settings.width_type == 'full' %}
    .contact-container-{{ section.id }} {
      max-width: 100%;
    }
    .contact-main-{{ section.id }} {
      padding-left: 0 !important;
      padding-right: 0 !important;
    }
    .contact-container-{{ section.id }} {
      padding-left: 1rem;
      padding-right: 1rem;
    }
    @media (min-width: 640px) {
      .contact-container-{{ section.id }} {
        padding-left: 1.5rem;
        padding-right: 1.5rem;
      }
    }
    @media (min-width: 1024px) {
      .contact-container-{{ section.id }} {
        padding-left: 2rem;
        padding-right: 2rem;
      }
    }
  {% else %}
    .contact-container-{{ section.id }} {
      max-width: 72rem;
    }
  {% endif %}
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="contact-layout-wrapper">
    <div class="contact-layout-container">
      <main class="contact-main contact-main-{{ section.id }} section-{{ section.id }}-padding">
        <div class="contact-container contact-container-{{ section.id }}">
          {%- if section.settings.heading != blank or section.settings.heading_text != blank -%}
            <div class="contact-hero">
              {%- if section.settings.heading != blank -%}
                <h1 class="contact-hero-title">{{ section.settings.heading }}</h1>
              {%- endif -%}
              {%- if section.settings.heading_text != blank -%}
                <p class="contact-hero-text">{{ section.settings.heading_text }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
          
          {%- liquid
            assign has_contact_info = false
            if section.settings.show_contact_info
              assign has_contact_info = true
            endif
            
            assign has_map = false
            if section.settings.show_map and section.settings.map_iframe != blank
              assign has_map = true
            endif
            
            assign has_social = false
            if section.settings.show_social
              assign has_social = true
            endif
            
            assign all_sections_hidden = true
            if has_contact_info or has_map or has_social
              assign all_sections_hidden = false
            endif
          -%}
          <div class="contact-form-grid{% if all_sections_hidden %} contact-form-grid-centered{% endif %}">
            <div class="contact-form-card">
              {%- if section.settings.form_title != blank -%}
                <h2 class="contact-form-title">{{ section.settings.form_title }}</h2>
              {%- endif -%}
              
              {%- liquid
                assign contact_form_class = 'contact-form'
                if settings.animations_reveal_on_scroll
                  assign contact_form_class = 'contact-form scroll-trigger animate--slide-in'
                endif
              -%}
              
              {%- form 'contact', id: 'ContactForm', class: contact_form_class -%}
                {%- if form.posted_successfully? -%}
                  <div class="form-status form-status-list form__message" tabindex="-1" autofocus>
                    {{- 'icon-success.svg' | inline_asset_content -}}
                    {{ 'templates.contact.form.post_success' | t }}
                  </div>
                {%- elsif form.errors -%}
                  <div class="form__message">
                    <h2 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
                      {{- 'icon-error.svg' | inline_asset_content -}}
                      {{ 'templates.contact.form.error_heading' | t }}
                    </h2>
                  </div>
                  <ul class="form-status-list caption-large" role="list">
                    <li>
                      <a href="#ContactForm-email" class="link">
                        {{ form.errors.translated_fields.email | capitalize }}
                        {{ form.errors.messages.email }}
                      </a>
                    </li>
                  </ul>
                {%- endif -%}
                
                <div class="contact-form-field">
                  <label class="contact-form-label" for="ContactForm-name">
                    <p class="contact-form-label-text">{{ section.settings.name_label | default: 'Full Name' }}</p>
                    <input
                      class="contact-form-input"
                      autocomplete="name"
                      type="text"
                      id="ContactForm-name"
                      name="contact[{{ 'templates.contact.form.name' | t }}]"
                      value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                      placeholder="{{ section.settings.name_placeholder | default: 'Enter your full name' }}"
                    >
                  </label>
                </div>
                
                <div class="contact-form-field">
                  <label class="contact-form-label" for="ContactForm-email">
                    <p class="contact-form-label-text">{{ section.settings.email_label | default: 'Email Address' }}</p>
                    <input
                      autocomplete="email"
                      type="email"
                      id="ContactForm-email"
                      class="contact-form-input"
                      name="contact[email]"
                      spellcheck="false"
                      autocapitalize="off"
                      value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                      aria-required="true"
                      {% if form.errors contains 'email' %}
                        aria-invalid="true"
                        aria-describedby="ContactForm-email-error"
                      {% endif %}
                      placeholder="{{ section.settings.email_placeholder | default: 'Enter your email address' }}"
                    >
                  </label>
                  {%- if form.errors contains 'email' -%}
                    <small class="contact__field-error" id="ContactForm-email-error">
                      <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
                      <span class="form__message">
                        <span class="svg-wrapper">
                          {{- 'icon-error.svg' | inline_asset_content -}}
                        </span>
                        {{- form.errors.translated_fields.email | capitalize }}
                        {{ form.errors.messages.email -}}
                      </span>
                    </small>
                  {%- endif -%}
                </div>
                
                <div class="contact-form-field">
                  <label class="contact-form-label" for="ContactForm-phone">
                    <p class="contact-form-label-text">{{ section.settings.phone_label | default: 'Phone Number' }}</p>
                    <input
                      type="tel"
                      id="ContactForm-phone"
                      class="contact-form-input"
                      autocomplete="tel"
                      name="contact[{{ 'templates.contact.form.phone' | t }}]"
                      pattern="[0-9\-]*"
                      value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
                      placeholder="{{ section.settings.phone_placeholder | default: 'Enter your phone number' }}"
                    >
                  </label>
                </div>
                
                <div class="contact-form-field">
                  <label class="contact-form-label" for="ContactForm-body">
                    <p class="contact-form-label-text">{{ section.settings.message_label | default: 'Your Message' }}</p>
                    <textarea
                      class="contact-form-textarea"
                      rows="10"
                      id="ContactForm-body"
                      name="contact[{{ 'templates.contact.form.comment' | t }}]"
                      placeholder="{{ section.settings.message_placeholder | default: 'Write your message here...' }}"
                    >{{- form.body -}}</textarea>
                  </label>
                </div>
                
                <div>
                  <button type="submit" class="contact-form-submit">
                    <span class="contact-form-submit-text">{{ section.settings.submit_button_text | default: 'Send Message' }}</span>
                  </button>
                </div>
              {%- endform -%}
            </div>
            
            {%- unless all_sections_hidden -%}
            <div class="contact-info-section">
              {%- if section.settings.show_contact_info -%}
                <div class="contact-info-card">
                  {%- if section.settings.contact_info_title != blank -%}
                    <h3 class="contact-info-title">{{ section.settings.contact_info_title }}</h3>
                  {%- endif -%}
                  <div class="contact-info-list">
                    {%- if section.settings.address != blank -%}
                      <div class="contact-info-item">
                        <span class="material-symbols-outlined contact-info-icon">{{ section.settings.address_icon | default: 'location_on' }}</span>
                        <p class="contact-info-text">{{ section.settings.address }}</p>
                      </div>
                    {%- endif -%}
                    {%- if section.settings.email != blank -%}
                      <div class="contact-info-item">
                        <span class="material-symbols-outlined contact-info-icon">{{ section.settings.email_icon | default: 'mail' }}</span>
                        <p class="contact-info-text">{{ section.settings.email }}</p>
                      </div>
                    {%- endif -%}
                    {%- if section.settings.phone != blank -%}
                      <div class="contact-info-item">
                        <span class="material-symbols-outlined contact-info-icon">{{ section.settings.phone_icon | default: 'call' }}</span>
                        <p class="contact-info-text">{{ section.settings.phone }}</p>
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
              
              {%- if section.settings.show_map and section.settings.map_iframe != blank -%}
                <div class="contact-map-card">
                  {{ section.settings.map_iframe }}
                </div>
              {%- endif -%}
              
              {%- if section.settings.show_social -%}
                <div class="contact-social-card">
                  {%- if section.settings.social_title != blank -%}
                    <h3 class="contact-social-title">{{ section.settings.social_title }}</h3>
                  {%- endif -%}
                  <div class="contact-social-links">
                    {%- if section.settings.facebook_url != blank -%}
                      <a class="contact-social-link" href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener noreferrer">
                        <svg aria-hidden="true" fill="currentColor" viewBox="0 0 24 24">
                          <path clip-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" fill-rule="evenodd"></path>
                        </svg>
                      </a>
                    {%- endif -%}
                    {%- if section.settings.twitter_url != blank -%}
                      <a class="contact-social-link" href="{{ section.settings.twitter_url }}" target="_blank" rel="noopener noreferrer">
                        <svg aria-hidden="true" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.71v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"></path>
                        </svg>
                      </a>
                    {%- endif -%}
                    {%- if section.settings.instagram_url != blank -%}
                      <a class="contact-social-link" href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener noreferrer">
                        <svg aria-hidden="true" fill="currentColor" viewBox="0 0 24 24">
                          <path clip-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.024.06 1.378.06 3.808s-.012 2.784-.06 3.808c-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.024.048-1.378.06-3.808.06s-2.784-.013-3.808-.06c-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.048-1.024-.06-1.378-.06-3.808s.012-2.784.06-3.808c.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 016.345 2.525c.636-.247 1.363-.416 2.427-.465C9.793 2.013 10.147 2 12.315 2zM12 7a5 5 0 100 10 5 5 0 000-10zm0-2a7 7 0 110 14 7 7 0 010-14zm6.406-1.11a1.44 1.44 0 100 2.88 1.44 1.44 0 000-2.88z" fill-rule="evenodd"></path>
                        </svg>
                      </a>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
            </div>
            {%- endunless -%}
          </div>
        </div>
      </main>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact Form",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Hero Section"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get in Touch"
    },
    {
      "type": "textarea",
      "id": "heading_text",
      "label": "Heading Text",
      "default": "We're here to help and answer any question you might have. We look forward to hearing from you."
    },
    {
      "type": "header",
      "content": "Contact Form"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Form Title",
      "default": "Send Us a Message"
    },
    {
      "type": "text",
      "id": "name_label",
      "label": "Name Label",
      "default": "Full Name"
    },
    {
      "type": "text",
      "id": "name_placeholder",
      "label": "Name Placeholder",
      "default": "Enter your full name"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email Label",
      "default": "Email Address"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email Placeholder",
      "default": "Enter your email address"
    },
    {
      "type": "text",
      "id": "phone_label",
      "label": "Phone Label",
      "default": "Phone Number"
    },
    {
      "type": "text",
      "id": "phone_placeholder",
      "label": "Phone Placeholder",
      "default": "Enter your phone number"
    },
    {
      "type": "text",
      "id": "message_label",
      "label": "Message Label",
      "default": "Your Message"
    },
    {
      "type": "text",
      "id": "message_placeholder",
      "label": "Message Placeholder",
      "default": "Write your message here..."
    },
    {
      "type": "text",
      "id": "submit_button_text",
      "label": "Submit Button Text",
      "default": "Send Message"
    },
    {
      "type": "header",
      "content": "Contact Information"
    },
    {
      "type": "checkbox",
      "id": "show_contact_info",
      "label": "Show Contact Information",
      "default": true
    },
    {
      "type": "text",
      "id": "contact_info_title",
      "label": "Contact Info Title",
      "default": "Contact Information"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "123 Printer Lane, Techville, CA 90210, USA"
    },
    {
      "type": "text",
      "id": "address_icon",
      "label": "Address Icon Name",
      "default": "location_on",
      "info": "Material Symbols icon name for address"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "support@inktonerstore.com"
    },
    {
      "type": "text",
      "id": "email_icon",
      "label": "Email Icon Name",
      "default": "mail",
      "info": "Material Symbols icon name for email"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone",
      "default": "+1 (555) 123-4567"
    },
    {
      "type": "text",
      "id": "phone_icon",
      "label": "Phone Icon Name",
      "default": "call",
      "info": "Material Symbols icon name for phone"
    },
    {
      "type": "header",
      "content": "Map"
    },
    {
      "type": "checkbox",
      "id": "show_map",
      "label": "Show Map",
      "default": true
    },
    {
      "type": "textarea",
      "id": "map_iframe",
      "label": "Map Iframe Embed Code",
      "info": "Paste the full iframe src URL from Google Maps or other map service. Example: https://www.google.com/maps/embed?pb=..."
    },
    {
      "type": "header",
      "content": "Social Links"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show Social Links",
      "default": true
    },
    {
      "type": "text",
      "id": "social_title",
      "label": "Social Title",
      "default": "Follow Us"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "Twitter URL"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "width_type",
      "label": "Section Width",
      "options": [
        {
          "value": "page",
          "label": "Page Width"
        },
        {
          "value": "full",
          "label": "Full Width"
        },
        {
          "value": "custom",
          "label": "Custom Width"
        }
      ],
      "default": "page"
    },
    {
      "type": "range",
      "id": "custom_width",
      "min": 400,
      "max": 2000,
      "step": 50,
      "unit": "px",
      "label": "Custom Max Width",
      "default": 1200,
      "info": "Only applies when Custom Width is selected"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}
