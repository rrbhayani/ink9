<link href="{{ 'rrp.css' | asset_url }}" rel="stylesheet">

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .rrp-stats-{{ section.id }} {
    border-top-color: {{ section.settings.border_color }};
    border-bottom-color: {{ section.settings.border_color }};
    padding-top: {{ section.settings.padding_vertical }}px;
    padding-bottom: {{ section.settings.padding_vertical }}px;
  }

  .rrp-stats-{{ section.id }} .rrp-stat-label {
    color: {{ section.settings.label_color }};
  }

  .rrp-stats-{{ section.id }} .rrp-stat-value {
    color: {{ section.settings.value_color }};
    font-size: {{ section.settings.value_size }}px;
  }

  .rrp-stats-{{ section.id }} .rrp-stat-note {
    color: {{ section.settings.note_color }};
  }

  @media (min-width: 768px) {
    .rrp-stats-{{ section.id }} {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    }
  }
{%- endstyle -%}

<div class="rrp-container">
<div class="rrp-stats rrp-stats-{{ section.id }} section-{{ section.id }}-padding">
  {% for block in section.blocks %}
    <div class="rrp-stat-item" {{ block.shopify_attributes }}>
      {% if block.settings.label != blank %}
        <p class="rrp-stat-label">{{ block.settings.label }}</p>
      {% endif %}
      {% if block.settings.value != blank %}
        <p class="rrp-stat-value">
          {{ block.settings.value }}
          {% if block.settings.note != blank %}
            <span class="rrp-stat-note">({{ block.settings.note }})</span>
          {% endif %}
        </p>
      {% endif %}
    </div>
  {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "RRP - Summary Stats",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Columns (Desktop)",
      "default": 4
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#e2e8f0"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label Color",
      "default": "#64748b"
    },
    {
      "type": "color",
      "id": "value_color",
      "label": "Value Color",
      "default": "#0f172a"
    },
    {
      "type": "range",
      "id": "value_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Value Font Size",
      "default": 18
    },
    {
      "type": "color",
      "id": "note_color",
      "label": "Note Color",
      "default": "#64748b"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Vertical Padding",
      "default": 32
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat Item",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Return Window"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "30 Days"
        },
        {
          "type": "text",
          "id": "note",
          "label": "Note (Optional)",
          "default": "Optional note"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RRP - Quick Summary Stats",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "label": "Return Window",
            "value": "30 Days"
          }
        },
        {
          "type": "stat",
          "settings": {
            "label": "Restocking Fee",
            "value": "30%",
            "note": "Non-defective"
          }
        },
        {
          "type": "stat",
          "settings": {
            "label": "Return Shipping",
            "value": "Customer Pays"
          }
        },
        {
          "type": "stat",
          "settings": {
            "label": "Processing Time",
            "value": "~10 Days"
          }
        }
      ]
    }
  ]
}
{% endschema %}
