                      <option
                        value="{{ variant.id }}"
                        {% if variant == product.selected_or_first_available_variant %}selected{% endif %}
                        {% unless variant.available %}disabled{% endunless %}
                      >
                        {{ variant.title }}
                        {%- if variant.available == false %} - {{ 'products.product.sold_out' | t }}{% endif %}
                      </option>
                    {% endfor %}
                  </select>
                  <span class="svg-wrapper">
                    {{ 'icon-caret.svg' | inline_asset_content }}
                  </span>
                </variant-selects>
              </div>
              {% endunless %}

              <!-- Quantity Picker (Matching Product Page Style) -->
              <div class="sticky-atc__quantity">
                <quantity-input class="quantity" data-url="{{ product.url }}" data-section="{{ section.id }}">
                  <button class="quantity__button" name="minus" type="button">
                    <span class="visually-hidden">{{ 'products.product.quantity.decrease' | t: product: product.title | escape }}</span>
                    <span class="svg-wrapper">
                      <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" class="icon icon-minus" fill="none" viewBox="0 0 10 2">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M.5 1C.5.7.7.5 1 .5h8a.5.5 0 110 1H1A.5.5 0 01.5 1z" fill="currentColor"></path>
                      </svg>
                    </span>
                  </button>
                  <input
                    class="quantity__input"
                    type="number"
                    name="quantity"
                    id="sticky-Quantity-{{ section.id }}"
                    data-cart-quantity="{{ cart_qty }}"
                    data-min="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                    min="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                    {% if product.selected_or_first_available_variant.quantity_rule.max %}
                      data-max="{{ product.selected_or_first_available_variant.quantity_rule.max }}"
                      max="{{ product.selected_or_first_available_variant.quantity_rule.max }}"
                    {% endif %}
                    step="{{ product.selected_or_first_available_variant.quantity_rule.increment }}"
                    value="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                    form="sticky-product-form-{{ section.id }}"
                  >
                  <button class="quantity__button" name="plus" type="button">
                    <span class="visually-hidden">{{ 'products.product.quantity.increase' | t: product: product.title | escape }}</span>
                    <span class="svg-wrapper">
                      <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" class="icon icon-plus" fill="none" viewBox="0 0 10 10">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M1 4.51a.5.5 0 000 1h3.5l.01 3.5a.5.5 0 001-.01V5.5l3.5-.01a.5.5 0 00-.01-1H5.5L5.49.99a.5.5 0 00-1 .01v3.5l-3.5.01H1z" fill="currentColor"></path>
                      </svg>
                    </span>
                  </button>
                </quantity-input>
              </div>

              <!-- Add to Cart Button -->
              <div class="sticky-atc__button">
                <product-form class="product-form" data-hide-errors="false" data-section-id="{{ section.id }}">
                  <form
                    method="post"
                    action="/cart/add"
                    id="sticky-product-form-{{ section.id }}"
                    accept-charset="UTF-8"
                    class="form"
                    enctype="multipart/form-data"
                    novalidate="novalidate"
                    data-type="add-to-cart-form"
                  >
                    <input type="hidden" name="form_type" value="product">
                    <input type="hidden" name="utf8" value="✓">
                    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                    
                    <button
                      id="sticky-ProductSubmitButton-{{ section.id }}"
                      type="submit"
                      name="add"
                      class="product-form__submit button button--full-width button--primary"
                      {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}
                    >
                      <span class="sticky-atc__button-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                        </svg>
                      </span>
                      <span class="sticky-atc__button-text">
                        {%- if product.selected_or_first_available_variant.available -%}
                          {{ 'products.product.add_to_cart' | t }}
                        {%- else -%}
                          {{ 'products.product.sold_out' | t }}
                        {%- endif -%}
                      </span>
                      <div class="loading__spinner hidden">
                        <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                          <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                        </svg>
                      </div>
                    </button>
                  </form>
                </product-form>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Sticky Add to Cart JavaScript -->
      <script>
        (function() {
          const sectionId = '{{ section.id }}';
          const stickyBar = document.getElementById('sticky-atc-' + sectionId);
          const productInfo = document.getElementById('ProductInfo-Sidebar-' + sectionId);
          
          if (!stickyBar || !productInfo) return;

          let lastScrollY = window.scrollY;
          let ticking = false;

          function updateStickyBar() {
            const productInfoRect = productInfo.getBoundingClientRect();
            const isProductInfoVisible = productInfoRect.bottom > 0 && productInfoRect.top < window.innerHeight;
            
            if (!isProductInfoVisible && productInfoRect.top < 0) {
              stickyBar.classList.remove('sticky-atc--hidden');
            } else {
              stickyBar.classList.add('sticky-atc--hidden');
            }
            
            ticking = false;
          }

          function onScroll() {
            lastScrollY = window.scrollY;
            
            if (!ticking) {
              window.requestAnimationFrame(updateStickyBar);
              ticking = true;
            }
          }


          // Sync variant selection between main form and sticky bar
          function syncVariants() {
            const mainVariantInput = document.querySelector('#product-form-' + sectionId + ' input[name="id"]');
            const stickyVariantSelect = document.querySelector('#sticky-variant-select-' + sectionId);
            const stickyVariantInput = stickyBar.querySelector('input[name="id"]');
            const mainProductInfoCenter = document.getElementById('ProductInfo-Center-' + sectionId);

            if (mainVariantInput && stickyVariantSelect && stickyVariantInput) {
              // Helper to apply the currently selected main variant to the sticky bar
              const applyMainToSticky = function() {
                const currentVariantId = mainVariantInput.value;
                if (!currentVariantId) return;
                stickyVariantSelect.value = currentVariantId;
                stickyVariantInput.value = currentVariantId;
                updateStickyPrice();
              };

              // Initial sync on load
              applyMainToSticky();

              // Sync from main product options to sticky when options change
              if (mainProductInfoCenter) {
                const optionInputs = mainProductInfoCenter.querySelectorAll(
                  '.product-form__input input[type="radio"], .product-form__input select'
                );

                optionInputs.forEach(function(input) {
                  input.addEventListener('change', function() {
                    // Allow Dawn's variant script to update the hidden input first
                    setTimeout(applyMainToSticky, 0);
                  });
                });
              }

              // Sync from main hidden variant input to sticky (in case theme fires change on it)
              mainVariantInput.addEventListener('change', applyMainToSticky);

              // Sync from sticky to main: update hidden input, trigger change (URL/price), and update sticky price
              stickyVariantSelect.addEventListener('change', function() {
                const newVariantId = this.value;
                if (!newVariantId) return;

                mainVariantInput.value = newVariantId;
                stickyVariantInput.value = newVariantId;

                mainVariantInput.dispatchEvent(new Event('change', { bubbles: true }));
                updateStickyPrice();
              });
            }
          }
          // Update sticky bar price when variant changes
          function updateStickyPrice() {
            const mainPrice = document.querySelector('#price-' + sectionId);
            const stickyPrice = document.querySelector('#sticky-price-' + sectionId);
            
            if (mainPrice && stickyPrice) {
              setTimeout(() => {
                stickyPrice.innerHTML = mainPrice.innerHTML;
              }, 100);
            }
          }

          // Sync quantity between main form and sticky bar
          function syncQuantity() {
            const mainQuantityInput = document.querySelector('#Quantity-' + sectionId);
            const stickyQuantityInput = document.querySelector('#sticky-Quantity-' + sectionId);
            
            if (mainQuantityInput && stickyQuantityInput) {
              // Sync from main to sticky
              mainQuantityInput.addEventListener('change', function() {
                stickyQuantityInput.value = this.value;
              });
              
              // Sync from sticky to main
              stickyQuantityInput.addEventListener('change', function() {
                mainQuantityInput.value = this.value;
              });
            }
          }

          // Initialize
          window.addEventListener('scroll', onScroll, { passive: true });
          window.addEventListener('resize', updateStickyBar);
          
          // Initial check
          updateStickyBar();
          
          // Sync functionality
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', function() {
              syncVariants();
              syncQuantity();
            });
          } else {
            syncVariants();
            syncQuantity();
          }

          // Re-initialize on section reload (theme editor)
          document.addEventListener('shopify:section:load', function(event) {
            if (event.detail.sectionId === sectionId) {
              setTimeout(function() {
                syncVariants();
                syncQuantity();
                updateStickyBar();
              }, 100);
            }
          });
        })();
      </script>
    {%- endif -%}
  {%- endfor -%}
</product-info>

