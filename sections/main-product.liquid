    <!-- Subtotal Calculation JavaScript -->
    <script>
      (function() {
        'use strict';

        const sectionId = '{{ section.id }}';
        let currentVariantPrice = {{ product.selected_or_first_available_variant.price }};
        
        // Store variant prices for quick lookup
        const variantPrices = {
          {% for variant in product.variants %}
            '{{ variant.id }}': {{ variant.price }}{% unless forloop.last %},{% endunless %}
          {% endfor %}
        };

        function formatMoney(cents) {
          // Convert cents to amount
          const amount = cents / 100;
          
          // Use toLocaleString to format with commas and prevent scientific notation
          const formattedAmount = amount.toLocaleString('en-US', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2,
            useGrouping: true
          });
          
          return '{{ cart.currency.symbol }}' + formattedAmount;
        }

        function updateSubtotal() {
          const subtotalElement = document.querySelector('#ProductSubtotal-' + sectionId + ' [data-subtotal-price] .price');
          const quantityInput = document.querySelector('#Quantity-' + sectionId);
          const productForm = document.querySelector('#product-form-' + sectionId);
          
          if (!subtotalElement || !quantityInput) return;

          const quantity = parseInt(quantityInput.value) || 1;
          
          // Try to get variant from form
          const variantInput = productForm ? productForm.querySelector('[name="id"]') : null;
          const variantId = variantInput ? variantInput.value : null;
          
          // Get price from variant data
          if (variantId && variantPrices[variantId]) {
            currentVariantPrice = variantPrices[variantId];
          }

          const subtotal = currentVariantPrice * quantity;
          const formattedSubtotal = formatMoney(subtotal);
          
          subtotalElement.textContent = formattedSubtotal;
        }

        function initSubtotalCalculator() {
          const quantityInput = document.querySelector('#Quantity-' + sectionId);
          const productForm = document.querySelector('#product-form-' + sectionId);
          
          if (!quantityInput) return;

          // Listen for quantity changes
          quantityInput.addEventListener('change', updateSubtotal);
          quantityInput.addEventListener('input', updateSubtotal);

          // Listen for quantity button clicks
          const quantityButtons = document.querySelectorAll('#Quantity-Form-' + sectionId + ' .quantity__button');
          quantityButtons.forEach(function(button) {
            button.addEventListener('click', function() {
              setTimeout(updateSubtotal, 50);
            });
          });

          // Listen for variant changes
          if (productForm) {
            productForm.addEventListener('change', function(e) {
              if (e.target.name === 'id' || e.target.name.startsWith('option')) {
                setTimeout(updateSubtotal, 100);
              }
            });
          }

          // Observer for price changes (in case variant picker updates the DOM)
          const priceElement = document.querySelector('#price-' + sectionId);
          if (priceElement) {
            const observer = new MutationObserver(function(mutations) {
              setTimeout(updateSubtotal, 50);
            });
            observer.observe(priceElement, { childList: true, subtree: true });
          }

          // Initial calculation
          updateSubtotal();
        }

        // Initialize when DOM is ready
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initSubtotalCalculator);
        } else {
          initSubtotalCalculator();
        }

        // Re-initialize on Shopify section updates (theme editor)
        document.addEventListener('shopify:section:load', function(event) {
          if (event.detail.sectionId === sectionId) {
            setTimeout(initSubtotalCalculator, 100);
          }
        });
      })();
    </script>

    <!-- Product Title Color Variant Update JavaScript -->
    <script>
      (function() {
        'use strict';

        const sectionId = '{{ section.id }}';
        const productTitle = '{{ product.title | escape }}';

        function initTitleUpdater() {
          const titleContainer = document.getElementById('ProductTitle-' + sectionId);
          const titleH1 = document.getElementById('ProductTitle-H1-' + sectionId);
          const titleH2 = document.getElementById('ProductTitle-H2-' + sectionId);
          
          if (!titleContainer || !titleH1 || !titleH2) return;

          // Check if color variant should be shown
          // Handle: 'true' (string), true (boolean), 'false' (string), false (boolean), undefined, or empty string
          const showColorVariantAttr = titleContainer.getAttribute('data-show-color-variant');
          let showColorVariant = false;
          
          if (showColorVariantAttr === 'true') {
            showColorVariant = true;
          } else if (showColorVariantAttr === undefined || showColorVariantAttr === '' || showColorVariantAttr === null) {
            // If attribute is missing, default to true (backward compatibility)
            showColorVariant = true;
          }
          // If showColorVariantAttr === 'false', showColorVariant remains false
          
          // If feature is disabled, ensure title shows only product title (remove any color variant)
          if (!showColorVariant) {
            // Always set to just the product title when feature is disabled
            titleH1.textContent = productTitle;
            titleH2.textContent = productTitle;
            return; // Feature is disabled, nothing to update
          }

          const colorOptionPosition = titleContainer.dataset.colorOptionPosition;
          if (!colorOptionPosition) return; // No Color option, nothing to update

          function updateTitleWithColorVariant(variant) {
            if (!variant) return;

            // Check setting again in case it changed
            const currentShowColorVariantAttr = titleContainer.getAttribute('data-show-color-variant');
            let currentShowColorVariant = false;
            if (currentShowColorVariantAttr === 'true') {
              currentShowColorVariant = true;
            } else if (currentShowColorVariantAttr === undefined || currentShowColorVariantAttr === '' || currentShowColorVariantAttr === null) {
              currentShowColorVariant = true; // Default to true if missing
            }
            
            if (!currentShowColorVariant) {
              titleH1.textContent = productTitle;
              titleH2.textContent = productTitle;
              return;
            }

            let colorValue = '';
            if (colorOptionPosition == '1') {
              colorValue = variant.option1 || '';
            } else if (colorOptionPosition == '2') {
              colorValue = variant.option2 || '';
            } else if (colorOptionPosition == '3') {
              colorValue = variant.option3 || '';
            }

            // Extract only the color name (remove ~ Pages info)
            if (colorValue) {
              const colorParts = colorValue.split('~');
              colorValue = colorParts[0].trim();
            }

            const titleText = colorValue ? productTitle + ', ' + colorValue : productTitle;
            titleH1.textContent = titleText;
            titleH2.textContent = titleText;
          }

          // Listen for variant changes via pub/sub
          if (typeof subscribe !== 'undefined' && typeof PUB_SUB_EVENTS !== 'undefined') {
            subscribe(PUB_SUB_EVENTS.variantChange, function(event) {
              if (event && event.data && event.data.variant && event.data.sectionId === sectionId) {
                updateTitleWithColorVariant(event.data.variant);
              }
            });
          }

          // Also listen for direct variant selection changes via MutationObserver
          const variantSelects = document.querySelector('variant-selects[data-section="' + sectionId + '"]');
          if (variantSelects) {
            const selectedVariantElement = variantSelects.querySelector('[data-selected-variant]');
            if (selectedVariantElement) {
              try {
                const initialVariant = JSON.parse(selectedVariantElement.textContent);
                updateTitleWithColorVariant(initialVariant);
              } catch (e) {
                // Ignore parsing errors
              }
            }

            // Watch for changes to the selected variant data
            const observer = new MutationObserver(function(mutations) {
              const selectedVariantElement = variantSelects.querySelector('[data-selected-variant]');
              if (selectedVariantElement) {
                try {
                  const variant = JSON.parse(selectedVariantElement.textContent);
                  updateTitleWithColorVariant(variant);
                } catch (e) {
                  // Ignore parsing errors
                }
              }
            });

            observer.observe(variantSelects, {
              childList: true,
              subtree: true,
              characterData: true
            });
          }

          // Watch for changes to the show-color-variant setting (when toggled in theme editor)
          const settingObserver = new MutationObserver(function(mutations) {
            const currentShowColorVariantAttr = titleContainer.getAttribute('data-show-color-variant');
            let currentShowColorVariant = false;
            if (currentShowColorVariantAttr === 'true') {
              currentShowColorVariant = true;
            } else if (currentShowColorVariantAttr === undefined || currentShowColorVariantAttr === '' || currentShowColorVariantAttr === null) {
              currentShowColorVariant = true; // Default to true if missing
            }
            
            if (!currentShowColorVariant) {
              // Setting is off, remove color variant from title
              titleH1.textContent = productTitle;
              titleH2.textContent = productTitle;
            } else {
              // Setting is on, update with current variant
              const variantSelects = document.querySelector('variant-selects[data-section="' + sectionId + '"]');
              if (variantSelects) {
                const selectedVariantElement = variantSelects.querySelector('[data-selected-variant]');
                if (selectedVariantElement) {
                  try {
                    const variant = JSON.parse(selectedVariantElement.textContent);
                    updateTitleWithColorVariant(variant);
                  } catch (e) {
                    // Ignore parsing errors
                  }
                }
              }
            }
          });

          settingObserver.observe(titleContainer, {
            attributes: true,
            attributeFilter: ['data-show-color-variant']
          });
        }

        // Initialize when DOM is ready
        function runInit() {
          // Small delay to ensure DOM is fully ready
          setTimeout(function() {
            initTitleUpdater();
          }, 50);
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', runInit);
        } else {
          runInit();
        }

        // Re-initialize on Shopify section updates (theme editor)
        document.addEventListener('shopify:section:load', function(event) {
          if (event.detail.sectionId === sectionId) {
            setTimeout(initTitleUpdater, 150);
          }
        });

        // Also listen for section:select event (when block is selected in editor)
        document.addEventListener('shopify:section:select', function(event) {
          if (event.detail.sectionId === sectionId) {
            setTimeout(initTitleUpdater, 100);
          }
        });
      })();
    </script>
  </div>

