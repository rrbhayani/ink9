{%- liquid
  assign primary_color = section.settings.primary_color | default: '#0d7ff2'
  assign background_light = section.settings.background_light | default: '#ffffff'
  assign background_dark = section.settings.background_dark | default: '#1f2937'
  assign text_color = section.settings.text_color | default: '#111827'
  assign muted_text = section.settings.muted_text | default: '#4b5563'
  assign muted_text_dark = section.settings.muted_text_dark | default: '#9ca3af'
  assign promo_background = section.settings.promo_background | default: '#111827'
  assign promo_text = section.settings.promo_text | default: '#ffffff'
  assign promo_muted = section.settings.promo_muted | default: '#d1d5db'
  assign promo_button = section.settings.promo_button | default: '#0d7ff2'
  assign promo_button_text = section.settings.promo_button_text | default: '#ffffff'
  assign icon_background_opacity = section.settings.icon_background_opacity | times: 0.01 | default: 0.2
  assign primary_rgb = primary_color | color_to_rgb
-%}

{%- style -%}
  .why-choose-{{ section.id }} {
    --primary: {{ primary_color }};
    --primary-rgb: {{ primary_rgb }};
    --feature-icon-bg: #eaf3ff;
    --background-light: {{ background_light }};
    --background-dark: {{ background_dark }};
    --text-color: {{ text_color }};
    --muted-color: {{ muted_text }};
    --muted-color-dark: {{ muted_text_dark }};
    --promo-background: {{ promo_background }};
    --promo-text: {{ promo_text }};
    --promo-muted: {{ promo_muted }};
    --promo-button: {{ promo_button }};
    --promo-button-text: {{ promo_button_text }};
    --section-pt: {{ section.settings.padding_top | default: 80 | append: 'px' }};
    --section-pb: {{ section.settings.padding_bottom | default: 80 | append: 'px' }};
    --heading-size: {{ section.settings.heading_font_size | default: 30 | append: 'px' }};
    --subheading-size: {{ section.settings.subheading_font_size | default: 18 | append: 'px' }};
    --feature-title-size: {{ section.settings.feature_title_font_size | default: 18 | append: 'px' }};
    --feature-description-size: {{ section.settings.feature_description_font_size | default: 16 | append: 'px' }};
    --icon-size: {{ section.settings.icon_font_size | default: 36 | append: 'px' }};
  }

  .why-choose-{{ section.id }} .section-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (min-width: 1024px) {
    .why-choose-{{ section.id }} .section-container {
      padding: 0 2rem;
    }
  }

  .why-choose-{{ section.id }} .features-section {
    background-color: var(--background-light);
    padding-top: var(--section-pt);
    padding-bottom: var(--section-pb);
  }

  .why-choose-{{ section.id }}.is-dark .features-section {
    background-color: var(--background-dark);
  }

  .why-choose-{{ section.id }} .features-title {
    font-size: var(--heading-size);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.025em;
    text-align: center;
    margin: 0 0 1rem;
    color: var(--text-color);
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .why-choose-{{ section.id }} .features-title.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  .why-choose-{{ section.id }} .features-subtitle {
    max-width: 720px;
    margin: 0 auto 2.5rem;
    text-align: center;
    color: var(--muted-color);
    line-height: 1.6;
    font-size: var(--subheading-size);
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    transition-delay: 0.2s;
  }

  .why-choose-{{ section.id }} .features-subtitle.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  .why-choose-{{ section.id }}.is-dark .features-title {
    color: #ffffff;
  }

  .why-choose-{{ section.id }}.is-dark .features-subtitle {
    color: var(--muted-color-dark);
  }

  .why-choose-{{ section.id }} .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    text-align: center;
  }

  @media (min-width: 640px) {
    .why-choose-{{ section.id }} .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .why-choose-{{ section.id }} .features-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .why-choose-{{ section.id }} .feature-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .why-choose-{{ section.id }} .feature-item.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  .why-choose-{{ section.id }} .feature-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 4rem;
    width: 4rem;
    border-radius: 9999px;
    background-color: var(--feature-icon-bg);
    color: var(--primary);
    margin-bottom: 0.75rem;
  }

  .why-choose-{{ section.id }} .feature-icon {
    font-size: var(--icon-size);
    line-height: 1;
  }

  .why-choose-{{ section.id }} .feature-icon-image {
    max-height: var(--icon-size);
    max-width: var(--icon-size);
    object-fit: contain;
  }

  .why-choose-{{ section.id }} .feature-title {
    font-size: var(--feature-title-size);
    font-weight: 700;
    margin: 0 0 0.25rem;
    color: var(--text-color);
  }

  .why-choose-{{ section.id }} .feature-description {
    margin: 0;
    color: var(--muted-color);
    line-height: 1.6;
    font-size: var(--feature-description-size);
  }

  .why-choose-{{ section.id }}.is-dark .feature-title {
    color: #ffffff;
  }

  .why-choose-{{ section.id }}.is-dark .feature-description {
    color: var(--muted-color-dark);
  }

  .why-choose-{{ section.id }} .promo-banner {
    background-color: var(--promo-background);
    padding: 4rem 0;
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    transition-delay: 0.6s;
  }

  .why-choose-{{ section.id }} .promo-banner.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  .why-choose-{{ section.id }} .promo-content {
    text-align: center;
  }

  .why-choose-{{ section.id }} .promo-title {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--promo-text);
    margin: 0;
  }

  .why-choose-{{ section.id }} .promo-text {
    margin-top: 1rem;
    font-size: 1.125rem;
    color: var(--promo-muted);
    margin-bottom: 0;
  }

  .why-choose-{{ section.id }} .promo-button {
    margin-top: 2rem;
    display: inline-block;
    background-color: var(--promo-button);
    color: var(--promo-button-text);
    font-weight: 700;
    padding: 0.75rem 2rem;
    border-radius: 0.5rem;
    font-size: 1.125rem;
    text-decoration: none;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .why-choose-{{ section.id }} .promo-button:hover {
    background-color: color-mix(in srgb, var(--promo-button) 90%, #000 10%);
    transform: translateY(-1px);
  }

  .why-choose-{{ section.id }} .promo-button:focus-visible {
    outline: 2px solid var(--promo-button);
    outline-offset: 2px;
  }

  @media (max-width: 639px) {
    .why-choose-{{ section.id }} .promo-title {
      font-size: 1.75rem;
    }

    .why-choose-{{ section.id }} .promo-text {
      font-size: 1rem;
    }
  }
{%- endstyle -%}

<section
  id="WhyChooseUs-{{ section.id }}"
  class="why-choose-{{ section.id }}{% if section.settings.enable_dark_mode %} is-dark{% endif %} color-{{ section.settings.color_scheme }} gradient"
>
  <div class="features-section">
    <div class="section-container">
      {%- if section.settings.heading != blank -%}
        <h2 class="features-title">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="features-subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}

      <div class="features-grid">
        {%- for block in section.blocks -%}
          <div class="feature-item" {{ block.shopify_attributes }}>
            <div class="feature-icon-wrapper">
              {%- if block.settings.icon_image != blank -%}
                <img
                  src="{{ block.settings.icon_image | image_url: width: 96 }}"
                  alt="{{ block.settings.icon_image.alt | escape }}"
                  width="{{ block.settings.icon_image.width }}"
                  height="{{ block.settings.icon_image.height }}"
                  loading="lazy"
                  class="feature-icon-image"
                >
              {%- else -%}
                <span class="material-symbols-outlined feature-icon">
                  {{- block.settings.icon | escape -}}
                </span>
              {%- endif -%}
            </div>
            {%- if block.settings.title != blank -%}
              <h3 class="feature-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="feature-description">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- if section.settings.show_promo -%}
    <div class="promo-banner">
      <div class="section-container promo-content">
        {%- if section.settings.promo_title != blank -%}
          <h3 class="promo-title">{{ section.settings.promo_title }}</h3>
        {%- endif -%}
        {%- if section.settings.promo_copy != blank -%}
          <p class="promo-text">{{ section.settings.promo_copy }}</p>
        {%- endif -%}
        {%- if section.settings.promo_button_label != blank and section.settings.promo_button_link != blank -%}
          <a class="promo-button" href="{{ section.settings.promo_button_link }}">
            {{ section.settings.promo_button_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
</section>

<script>
(function() {
  function initScrollAnimations() {
    const section = document.getElementById('WhyChooseUs-{{ section.id }}');
    if (!section) return;

    const featuresTitle = section.querySelector('.features-title');
    const featuresSubtitle = section.querySelector('.features-subtitle');
    const featureItems = section.querySelectorAll('.feature-item');
    const promoBanner = section.querySelector('.promo-banner');

    // Create Intersection Observer
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-in');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    // Observe title and subtitle first
    if (featuresTitle) {
      observer.observe(featuresTitle);
    }
    if (featuresSubtitle) {
      observer.observe(featuresSubtitle);
    }

    // Observe feature items with staggered delays
    featureItems.forEach((item, index) => {
      // Add staggered animation delay starting after title/subtitle animations
      item.style.transitionDelay = `${0.4 + (index * 0.1)}s`;
      observer.observe(item);
    });

    // Observe promo banner
    if (promoBanner) {
      observer.observe(promoBanner);
    }
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollAnimations);
  } else {
    initScrollAnimations();
  }

  // Re-initialize on section load (for theme editor)
  document.addEventListener('shopify:section:load', function(event) {
    if (event.detail.sectionId === '{{ section.id }}') {
      setTimeout(initScrollAnimations, 100);
    }
  });
})();
</script>

{% schema %}
