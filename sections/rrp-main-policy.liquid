          "default": "#dcfce7"
        },
        {
          "type": "color",
          "id": "badge_text_color",
          "label": "Badge Text Color",
          "default": "#15803d"
        },
        {
          "type": "text",
          "id": "badge_1_icon",
          "label": "Badge 1 Icon",
          "default": "check_circle",
          "info": "Material Symbols icon name"
        },
        {
          "type": "text",
          "id": "badge_1_text",
          "label": "Badge 1 Text",
          "default": "No Restocking Fee"
        },
        {
          "type": "text",
          "id": "badge_2_icon",
          "label": "Badge 2 Icon",
          "default": "local_shipping",
          "info": "Material Symbols icon name"
        },
        {
          "type": "text",
          "id": "badge_2_text",
          "label": "Badge 2 Text",
          "default": "We Pay Return Shipping"
        },
        {
          "type": "text",
          "id": "badge_3_icon",
          "label": "Badge 3 Icon",
          "default": "check_circle",
          "info": "Optional"
        },
        {
          "type": "text",
          "id": "badge_3_text",
          "label": "Badge 3 Text",
          "default": "Extra badge"
        }
      ]
    },
    {
      "type": "policy_card",
      "name": "Policy Card",
      "settings": [
        {
